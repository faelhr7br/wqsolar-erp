datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPERADMIN
  ADMIN
  PARTNER
  OPERATOR
}

enum ObraStatus {
  EM_ANDAMENTO
  FINALIZADA
  PENDENTE_RECEBIMENTO
  CANCELADA
}

enum MovimentacaoTipo {
  ENTRADA
  SAIDA
}

enum CategoriaEntrada {
  SINAL
  PARCIAL
  PAGAMENTO_FINAL
}

enum CategoriaSaida {
  UBER
  DIARIA
  ALIMENTACAO
  MATERIAL
  COMBUSTIVEL
  FERRAMENTAS
  HOSPEDAGEM
  OUTROS
}

model Tenant {
  id        String   @id @default(uuid())
  nome      String
  slug      String   @unique
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  obras         Obra[]
  funcionarios  Funcionario[]
  movimentacoes Movimentacao[]
  reembolsos    Reembolso[]
  relatorios    Relatorio[]
  leads         Lead[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  nome      String
  senhaHash String
  telefone  String?
  role      Role     @default(PARTNER)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  socio     Socio?
}

model Socio {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  percentualLucro Float    @default(50.0) // 50/50 standard
  createdAt       DateTime @default(now())

  movimentacoes   Movimentacao[] // Out-of-pocket expenses funded by this partner
  reembolsosPagos Reembolso[]    @relation("SocioReembolsado")
}

model Obra {
  id              String     @id @default(uuid())
  nome            String     // e.g. "João Solar" or "Obra João"
  cliente         String
  valorFechado    Decimal    @db.Decimal(12, 2)
  status          ObraStatus @default(EM_ANDAMENTO)
  observacoes     String?
  dataCriacao     DateTime   @default(now())
  dataFinalizacao DateTime?
  tenantId        String
  tenant          Tenant     @relation(fields: [tenantId], references: [id])

  movimentacoes Movimentacao[]
  diasTrabalho  DiaTrabalhado[]
  reembolsos    Reembolso[]

  @@index([tenantId])
  @@index([status])
}

model Funcionario {
  id               String   @id @default(uuid())
  nome             String
  telefone         String?
  valorDiariaPadrao Decimal  @db.Decimal(10, 2)
  ativo            Boolean  @default(true)
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  createdAt        DateTime @default(now())

  diasTrabalho      DiaTrabalhadoFuncionario[]
  movimentacoesPago Movimentacao[] // Register if a payment was directly made to this worker (e.g. Diária)
}

model Movimentacao {
  id               String            @id @default(uuid())
  valor            Decimal           @db.Decimal(12, 2)
  tipo             MovimentacaoTipo
  categoriaEntrada CategoriaEntrada?
  categoriaSaida   CategoriaSaida?
  descricao        String?
  data             DateTime          @default(now())
  comprovanteUrl   String?
  
  obraId           String
  obra             Obra              @relation(fields: [obraId], references: [id], onDelete: Cascade)
  
  // Who paid this out of pocket? Null = Paid from Company Box (Caixa)
  socioId          String?
  socio            Socio?            @relation(fields: [socioId], references: [id])

  // Was this paid to an employee? (e.g. a worker's daily rate)
  funcionarioId    String?
  funcionario      Funcionario?      @relation(fields: [funcionarioId], references: [id])
  
  tenantId         String
  tenant           Tenant            @relation(fields: [tenantId], references: [id])

  createdAt        DateTime          @default(now())

  @@index([obraId])
  @@index([socioId])
  @@index([tipo])
}

model DiaTrabalhado {
  id        String   @id @default(uuid())
  data      DateTime @default(dbgenerated("CURRENT_DATE"))
  obraId    String
  obra      Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  equipe    DiaTrabalhadoFuncionario[]

  @@unique([data, obraId])
}

model DiaTrabalhadoFuncionario {
  diaTrabalhadoId String
  diaTrabalhado   DiaTrabalhado @relation(fields: [diaTrabalhadoId], references: [id], onDelete: Cascade)
  
  funcionarioId   String
  funcionario     Funcionario   @relation(fields: [funcionarioId], references: [id])

  @@id([diaTrabalhadoId, funcionarioId])
}

model Reembolso {
  id             String   @id @default(uuid())
  valor          Decimal  @db.Decimal(12, 2)
  data           DateTime @default(now())
  
  socioId        String
  socio          Socio    @relation("SocioReembolsado", fields: [socioId], references: [id])
  
  obraId         String
  obra           Obra     @relation(fields: [obraId], references: [id], onDelete: Cascade)
  
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  @@index([socioId])
  @@index([obraId])
}

model Relatorio {
  id             String   @id @default(uuid())
  tipo           String   // "SEMANAL", "MENSAL", "ANUAL"
  dataInicio     DateTime
  dataFim        DateTime
  dadosJson      Json
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  createdAt      DateTime @default(now())
}

model MensagemWhatsapp {
  id             String   @id @default(uuid())
  mensagemId     String   @unique
  remetente      String
  conteudo       String
  comandoValido  Boolean  @default(false)
  comandoTipo    String?
  respostaEnviada String?
  createdAt      DateTime @default(now())
}

model Lead {
  id            String   @id @default(uuid())
  nome          String
  cliente       String
  telefone      String?
  endereco      String?
  kwpEstimado   Decimal? @db.Decimal(10, 2)
  valorProposta Decimal? @db.Decimal(12, 2)
  status        String   @default("NOVO_LEAD") // NOVO_LEAD, VISITA_TECNICA, PROPOSTA_ENVIADA, NEGOCIACAO, CONTRATO_FECHADO, PERDIDO
  observacoes   String?
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([status])
}

